# Example site for lunar-web behind Nginx → Next.js (PM2 on 127.0.0.1:3000).
# Use 127.0.0.1 (not "localhost") so Nginx does not pick ::1 while Node listens on IPv4 only.

upstream lunar_web_next {
    server 127.0.0.1:3000;
    keepalive 32;
}

server {
    listen 443 ssl http2;
    server_name lunar-web.endeavourdigital.cloud;

    # ssl_certificate /etc/letsencrypt/live/.../fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/.../privkey.pem;

    access_log /var/log/nginx/lunar-web.access.log;
    error_log  /var/log/nginx/lunar-web.error.log warn;

    location / {
        proxy_pass http://lunar_web_next;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        # Next cold start / slow pages — short defaults cause false 502s
        proxy_connect_timeout 75s;
        proxy_send_timeout 75s;
        proxy_read_timeout 75s;

        proxy_buffering on;
        proxy_buffer_size 128k;
        proxy_buffers 8 256k;
        proxy_busy_buffers_size 256k;
    }
}
